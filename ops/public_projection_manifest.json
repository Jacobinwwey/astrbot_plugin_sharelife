{
  "managed_roots": [
    ".github",
    ".gitignore",
    "CONTRIBUTING.md",
    "DESIGN.md",
    "DEVELOPER_GUIDE.md",
    "Dockerfile",
    "Makefile",
    "QUICKSTART.md",
    "README.md",
    "_conf_schema.json",
    "assets",
    "config.template.yaml",
    "docker-compose.observability.yml",
    "docker-compose.yml",
    "docs",
    "examples",
    "main.py",
    "metadata.yaml",
    "ops",
    "requirements.txt",
    "scripts",
    "sharelife",
    "templates",
    "tests"
  ],
  "include": [
    ".github/**",
    ".gitignore",
    "CONTRIBUTING.md",
    "DESIGN.md",
    "DEVELOPER_GUIDE.md",
    "Dockerfile",
    "Makefile",
    "QUICKSTART.md",
    "README.md",
    "_conf_schema.json",
    "assets/**",
    "config.template.yaml",
    "docker-compose.observability.yml",
    "docker-compose.yml",
    "docs/**",
    "examples/**",
    "main.py",
    "metadata.yaml",
    "ops/**",
    "requirements.txt",
    "scripts/**",
    "sharelife/**",
    "templates/**",
    "tests/**"
  ],
  "exclude": [
    ".pytest_cache/**",
    "**/__pycache__/**",
    "**/*.pyc",
    "docs/.vitepress/cache/**",
    "docs/.vitepress/dist/**",
    "docs/.vitepress/private-sidebar.json",
    "docs/private/**",
    "docs/*/private/**",
    "docs/public/private/**",
    "docs-private/**",
    "output/**",
    "ref/**",
    "scripts/sync_local_private_docs.py",
    "tests/meta/test_private_docs_portal_surface.py",
    "**/*.local.toml",
    "**/*.pem",
    "**/*.key",
    "**/*.p12",
    "**/id_rsa"
  ]
}
